---
interface Props {
  float?: boolean;
  accent?: string;
  green?: string;
}
const { float = true, accent = "#1f6fe5", green = "#2f9e44" } = Astro.props;

const fw = 440, fh = 112, padX = 8, padY = 10;
const iw = fw - padX * 2, ih = fh - padY * 2;
const real = [0.34, 0.42, 0.38, 0.52, 0.6, 0.57, 0.71];
const pred = [0.71, 0.79, 0.86, 0.95];
const n = [...real, ...pred.slice(1)].length - 1;
const X = (i: number) => padX + (iw * i) / n;
const Y = (v: number) => padY + ih * (1 - v);
const ptsReal = real.map((v, i) => `${X(i)},${Y(v)}`).join(" ");
const offset = real.length - 1;
const ptsPred = pred.map((v, i) => `${X(offset + i)},${Y(v)}`).join(" ");
const areaD = `M${X(0)},${Y(real[0])} L${real.map((v, i) => `${X(i)},${Y(v)}`).join(" L")} L${X(offset)},${fh - padY} L${padX},${fh - padY} Z`;

const ringR = 13;
const ringCirc = 2 * Math.PI * ringR;
const ringDash = `${(ringCirc * 0.32).toFixed(2)} ${ringCirc.toFixed(2)}`;

const rows = [
  { opp: "Renovación Plataforma", account: "TechSolutions",   prob: 84, value: "$135,000" },
  { opp: "Expansión Servicios",   account: "Grupo Industrial", prob: 72, value: "$98,000"  },
  { opp: "Implementación CRP",    account: "Logística Andina", prob: 65, value: "$80,000"  },
];
const probColor = (p: number) => p >= 75 ? green : p >= 60 ? "#f5bd4f" : "#f4655a";
---

<div class={`device${float ? " float" : ""}`}>
  <div class="device-bar">
    <span class="dot3 r"></span><span class="dot3 y"></span><span class="dot3 g"></span>
    <span class="addr">app.miforecast.com</span>
  </div>
  <span class="device-tag">Vista ilustrativa</span>
  <div class="dash">
    <div style="display:grid;grid-template-columns:1fr 200px;gap:10px;margin-bottom:10px">
      <div>
        <div class="dash-metric">
          <div>
            <div class="dash-metric-lbl">Proyección de Ventas</div>
            <div class="dash-metric-val">$2.45M <span class="dash-delta-up">▲ +24%</span></div>
          </div>
          <div class="legend">
            <span><i style={`background:${accent}`}></i>Real</span>
            <span><i style={`background:${green}`}></i>Proyección IA</span>
          </div>
        </div>
        <svg viewBox={`0 0 ${fw} ${fh}`} width="100%" style="display:block">
          <defs>
            <linearGradient id="fcArea" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color={accent} stop-opacity="0.28" />
              <stop offset="100%" stop-color={accent} stop-opacity="0" />
            </linearGradient>
          </defs>
          {[0.25, 0.5, 0.75].map((g) => (
            <line x1={padX} x2={fw - padX} y1={Y(g)} y2={Y(g)} stroke="rgba(255,255,255,.05)" />
          ))}
          <path d={areaD} fill="url(#fcArea)" />
          <polyline points={ptsReal} fill="none" stroke={accent} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          <polyline points={ptsPred} fill="none" stroke={green} stroke-width="2" stroke-dasharray="4 4" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx={X(offset)} cy={Y(real[real.length - 1])} r="3" fill={accent} stroke="#0c1828" stroke-width="1.5" />
          <circle cx={X(n)} cy={Y(pred[pred.length - 1])} r="3.5" fill={green} stroke="#0c1828" stroke-width="1.5" />
        </svg>
      </div>
      <div style="display:flex;flex-direction:column;gap:8px">
        <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:8px;padding:11px 10px 8px">
          <div style="color:#6a7f98;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.05em">Oportunidades Activas</div>
          <div style="color:#fff;font-size:26px;font-weight:800;letter-spacing:-.03em;line-height:1;margin-top:3px">128</div>
          <div style="color:#5fd07f;font-size:9.5px;font-weight:600;margin-top:3px">▲ +15% vs período anterior</div>
          <svg viewBox="0 0 120 26" width="100%" style="display:block;margin-top:7px">
            <defs>
              <linearGradient id="spkArea" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color={green} stop-opacity="0.2" />
                <stop offset="100%" stop-color={green} stop-opacity="0" />
              </linearGradient>
            </defs>
            <path d="M0,22 L18,19 L36,21 L54,13 L72,9 L90,11 L108,5 L120,3 L120,26 L0,26 Z" fill="url(#spkArea)" />
            <polyline points="0,22 18,19 36,21 54,13 72,9 90,11 108,5 120,3" fill="none" stroke={green} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <circle cx="120" cy="3" r="2.5" fill={green} />
          </svg>
        </div>
        <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:8px;padding:11px 10px">
          <div style="color:#6a7f98;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.05em">Tasa de Cierre Estimada</div>
          <div style="display:flex;align-items:center;gap:10px;margin-top:5px">
            <div style="color:#fff;font-size:26px;font-weight:800;letter-spacing:-.03em;line-height:1">32%</div>
            <svg viewBox="0 0 36 36" width="36" height="36" style="flex:none">
              <circle cx="18" cy="18" r={ringR} fill="none" stroke="rgba(255,255,255,.07)" stroke-width="3.5" />
              <circle cx="18" cy="18" r={ringR} fill="none" stroke={accent} stroke-width="3.5"
                stroke-dasharray={ringDash} stroke-linecap="round" transform="rotate(-90 18 18)" />
            </svg>
          </div>
          <div style="color:#4d91f5;font-size:9.5px;font-weight:600;margin-top:4px">▲ +6% vs período anterior</div>
        </div>
      </div>
    </div>
    <div class="dash-card">
      <div class="ch-head" style="margin-bottom:8px">
        <span class="t">Top oportunidades recomendadas por IA</span>
        <span class="ai-badge">IA activa</span>
      </div>
      <div>
        <div style="display:grid;grid-template-columns:1.7fr 1.1fr 1.6fr 0.9fr;gap:0 6px;padding:0 4px 7px;border-bottom:1px solid rgba(255,255,255,.06)">
          {["Oportunidad", "Cuenta", "Prob. de cierre", "Valor est."].map((h) => (
            <span style="color:#3d5570;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.05em">{h}</span>
          ))}
        </div>
        {rows.map((row) => (
          <div style="display:grid;grid-template-columns:1.7fr 1.1fr 1.6fr 0.9fr;gap:0 6px;padding:7px 4px;border-bottom:1px solid rgba(255,255,255,.04);align-items:center">
            <span style="color:#cdd9e6;font-size:10.5px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{row.opp}</span>
            <span style="color:#7d8ea3;font-size:10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{row.account}</span>
            <div style="display:flex;align-items:center;gap:5px">
              <div style="flex:1;height:4px;border-radius:999px;background:rgba(255,255,255,.08);overflow:hidden">
                <div style={`width:${row.prob}%;height:100%;background:${probColor(row.prob)};border-radius:999px`}></div>
              </div>
              <span style={`color:${probColor(row.prob)};font-size:10px;font-weight:700;flex:none;min-width:26px`}>{row.prob}%</span>
            </div>
            <span style="color:#cdd9e6;font-size:10px;font-weight:600">{row.value}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
