---
const initVal = 72;
const initProj = Math.round(initVal * 1.18);
const initPct = Math.min(100, Math.round((initProj / 100) * 100));

const FEATURES = [
  {
    icon: "M3 9h18M9 3v18M3 5a2 2 0 012-2h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2z",
    title: "Grilla de oportunidades",
    desc: "Optimizada para requerir el menor tiempo en ingreso de datos.",
  },
  {
    icon: "M12 3l9 5-9 5-9-5 9-5zM3 13l9 5 9-5",
    title: "Sin reuniones de seguimiento",
    desc: "El estado del pipeline está siempre visible. Sin reportes manuales, sin esperar el cierre de mes.",
  },
  {
    icon: "M4 20V10M10 20V4M16 20v-7M22 20H2",
    title: "Forecast que se cumple",
    desc: "Basado en el comportamiento histórico de tu equipo, no en intuición ni hojas de cálculo.",
  },
];
---

<section class="sec showcase reveal">
  <div class="wrap">

    <div class="sec-head center">
      <span class="kicker-tag">Toma de decisiones</span>
      <h2 style="font-size:clamp(28px,3.6vw,40px);font-weight:800;margin-top:16px">
        Tu equipo sabe qué hacer<br />para cerrar el mes antes de que empiece
      </h2>
      <p style="margin-top:16px;font-size:17px;color:var(--muted)">
        Simula escenarios, ajusta el foco de tu equipo y llega a la meta con un plan concreto — no con corazonadas.
      </p>
    </div>

    <div class="sim" style="max-width:560px;margin:40px auto 0">
      <div class="sim-head">
        <span class="t">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
            stroke-linecap="round" stroke-linejoin="round"
            style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:4px">
            <path d="M12 14l4-4M5 19a9 9 0 1114 0" />
          </svg>
          Simulador de ventas
        </span>
        <span class="tag">vista ilustrativa</span>
      </div>
      <div class="sim-row">
        <span class="big" id="sim-proj">{initProj}%</span>
        <span class="meta">de la meta proyectada</span>
      </div>
      <input id="sim-range" type="range" min="40" max="100" value={initVal} />
      <div class="sim-bar"><i id="sim-bar" style={`width:${initPct}%`}></i></div>
      <div class="sim-scale"><span>Escenario conservador</span><span>Meta</span></div>
    </div>

    <div class="show-feat-row">
      {FEATURES.map(({ icon, title, desc }) => (
        <div class="show-item">
          <span class="b">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <path d={icon} />
            </svg>
          </span>
          <div>
            <h4>{title}</h4>
            <p>{desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  const range = document.getElementById('sim-range') as HTMLInputElement;
  const projEl = document.getElementById('sim-proj');
  const barEl  = document.getElementById('sim-bar') as HTMLElement;

  if (range && projEl && barEl) {
    range.addEventListener('input', () => {
      const val  = +range.value;
      const proj = Math.round(val * 1.18);
      const pct  = Math.min(100, Math.round((proj / 100) * 100));
      projEl.textContent = `${proj}%`;
      barEl.style.width  = `${pct}%`;
    });
  }
</script>
