---
---

<section id="contacto" class="sec reveal">
  <div class="wrap contact-grid">
    <div class="contact-side">
      <span class="kicker-tag">Contáctanos</span>
      <h2 style="margin-top:16px">¿Hablamos?</h2>
      <p class="lead">Escríbenos y te responderemos a la brevedad.</p>
      <div class="mailblock">
        <a class="mailcard" href="mailto:ventas@miforecast.com?subject=Información%20sobre%20Ventas">
          <span class="mi">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 7l9 6 9-6M3 7a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
            </svg>
          </span>
          <div>
            <div class="lab">Ventas</div>
            <div class="em">ventas@miforecast.com</div>
          </div>
        </a>
        <a class="mailcard" href="mailto:soporte@miforecast.com?subject=Consulta%20cliente">
          <span class="mi">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 12a8 8 0 0116 0M4 12v3a2 2 0 002 2h1v-5H5a1 1 0 00-1 1zm16 0v3a2 2 0 01-2 2h-1v-5h2a1 1 0 011 1zM12 20a3 3 0 003-3" />
            </svg>
          </span>
          <div>
            <div class="lab">Soporte y consultas de clientes</div>
            <div class="em">soporte@miforecast.com</div>
          </div>
        </a>
      </div>
    </div>
    <form class="form" id="contact-form">
      <div class="row">
        <div class="field"><label>Nombre*</label><input type="text" required placeholder="Tu nombre" /></div>
        <div class="field"><label>Email*</label><input type="email" required placeholder="tu@empresa.com" /></div>
      </div>
      <div class="field"><label>Asunto</label><input type="text" placeholder="Asunto" /></div>
      <div class="field"><label>Mensaje*</label><textarea required placeholder="Cuéntanos en qué te ayudamos"></textarea></div>
      <button class="btn btn-primary" type="submit">Enviar</button>
      <div class="form-ok" id="form-ok">¡Gracias! Te contactaremos pronto.</div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form');
  const ok = document.getElementById('form-ok');
  if (form && ok) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      ok.classList.add('show');
    });
  }
</script>
